{
  "name": "dunder",
  "private": true,
  "workspaces": [
    "examples/*",
    "extern/tstl"
  ],
  "type": "module",
  "scripts": {
    "driver": "node --experimental-transform-types --no-warnings src/main.ts",
    "compare": "node --experimental-transform-types --no-warnings scripts/compare.ts",
    "replay-sim": "node --experimental-transform-types --no-warnings scripts/replay/replay-sim.ts",
    "replay-bench": "node --experimental-transform-types --no-warnings scripts/replay/replay-bench.ts",
    "typecheck": "tsgo --noEmit -p .",
    "tstl-tests": "DUNDER_TEST=1 npx jest --config scripts/tstl-harness/jest.config.cjs",
    "lint": "oxlint --type-aware",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check ."
  },
  "dependencies": {
    "@typescript/native-preview": "^7.0.0-dev.20260424.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "oxlint-tsgolint": "^0.21.1"
  }
}
